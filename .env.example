# Local Deployment workflow
NEON_PROJECT_ID="iskriva-baunow-gjt"

# Mailing
RESEND_API_KEY=""
# Database
DATABASE_URL="postgresql://user:password@localhost:5432/eu_project_manager?schema=public"

# Auth.js
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
# AUTH_URL is optional - the app uses trustHost to auto-detect the URL from request headers
# Only set this if you need to override the auto-detected URL (e.g., behind a proxy)
# AUTH_URL="http://localhost:3000"

# Sentry (optional)
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
SENTRY_ENABLED="true"
SENTRY_ENVIRONMENT=""

# Environment
NODE_ENV="development"
# Update the port if running on a different port (e.g., http://localhost:3005)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
