# Neon Test Branch Configuration
# Copy this file to .env.test and fill in the values

# Test database connection string (from Neon test branch)
DATABASE_URL_TEST=postgresql://user:pass@ep-test-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth secret for testing (can be different from production)
AUTH_SECRET=test-secret-key-change-me

# Neon API credentials for automated branch management (used by setup-test-branch.sh)
# Get API key from: https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=nkey_xxx
NEON_PROJECT_ID=iskriva-baunow-gjt
